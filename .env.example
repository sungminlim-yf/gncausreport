# ── 슬랙 게시·봇 설정 (실제 토큰은 .env 에, 절대 커밋 금지) ──

# 전송 방식: 1단계는 webhook, 2단계+는 webapi (D21)
SLACK_TRANSPORT=webhook

# 1단계 스캐폴드 — Incoming Webhook (단방향 게시)
SLACK_WEBHOOK_URL=

# 2단계+ — Web API + Socket Mode 봇 (게시·승인·Q&A 일원화, D21·D13)
SLACK_BOT_TOKEN=        # xoxb-... (chat:write 등)
SLACK_APP_TOKEN=        # xapp-... (Socket Mode connections:write)

# 채널 ID 매핑 — 별칭(SLACK_CHANNEL_<별칭>)으로 참조 (C로 시작하는 채널 ID)
SLACK_CHANNEL_EXEC_TEAM=
SLACK_CHANNEL_STAGING=
SLACK_CHANNEL_OPS=

# 승인자 화이트리스트 — 쉼표 구분 슬랙 user ID (U로 시작) (D17)
SLACK_APPROVERS=

# ── 봇 운영 (Socket Mode 상시 프로세스, D13) ──
# archive 활성 보관 개월 수 (D24)
ARCHIVE_ACTIVE_MONTHS=6
# 3단계 Q&A 자동응답 활성 스위치(기본 off). 2단계에서는 비워두면 봇이 스레드에서 침묵.
QA_ENABLED=
# Q&A 답변 모델 — 채널 레벨 질문은 여러 보고서를 한 번에 근거로 쓰므로 가벼운 모델 권장.
# (Opus 는 다중 보고서에서 타임아웃 위험. 예: claude-haiku-4-5 / claude-sonnet-4-6. 비우면 세션 기본 모델)
QA_MODEL=claude-haiku-4-5
# (선택) Q&A 답변 생성 타임아웃(초, 기본 180)
QA_TIMEOUT=
# 채널에 직접 올린 질문(스레드 아님)에 답할 채널 ID(쉼표). 비우면 exec-team 채널 기본 허용.
# 스레드 질문은 채널과 무관하게 항상 동작(바인딩된 글 한정). 채널 레벨만 이 목록으로 제한.
QA_CHANNELS=
# 보고서에 답이 없을 때 Claude 웹 검색으로 폴백 답변(기본 on). 답변에 '보고서 미검증·웹 기반' 라벨 부착. 끄려면 0.
QA_WEB_FALLBACK=1
# 웹 검색 폴백 타임아웃(초, 기본 300 — 검색·종합이라 그라운딩보다 길게)
QA_WEB_TIMEOUT=
# 슬랙 /gnc 즉시 조사 트리거가 실행할 claude CLI 경로(미설정 시 PATH 탐색)
# Mac 로컬: 비워두면 ~/.local/bin/claude 사용. 리눅스 서버: 보통 /home/ubuntu/.local/bin/claude
CLAUDE_BIN=

# ── Claude 인증 (서버/헤드리스 — 종량제 API키) ──
# 맥 로컬에서는 구독 로그인으로 동작하므로 비워둠. 클라우드 VM 에서는 종량제 키 필수.
# Anthropic Console(console.anthropic.com)에서 발급. 설정 시 claude -p 가 이 키로 과금됨.
ANTHROPIC_API_KEY=

# ── 검색·수집 (D11) ──
# firecrawl MCP는 Claude Code 설정에서 연결. 직접 호출 시에만 키 사용.
FIRECRAWL_API_KEY=

# ── 비용 가드 (D16) ──
# /brief 1회 기본 토큰 상한 (0이면 무제한)
BRIEF_DEFAULT_BUDGET=0

# ── 이메일 발송 (Resend) — 승인된 보고서를 메일 리스트로(별도 버튼) ──
# resend.com 가입 → API Keys 에서 발급. 절대 커밋 금지(.env 만).
RESEND_API_KEY=
# 발신자. 나중에 도메인 인증 후 회사 주소로 이 줄만 바꾸면 됨.
#   인증 전 테스트: onboarding@resend.dev (Resend 가입 이메일 본인에게만 발송 가능)
#   인증 후 예시:   "GnC AUS Report <reports@youngfoods.com.au>"
EMAIL_FROM=onboarding@resend.dev
# 수신자 목록(쉼표 구분). 서로의 주소가 안 보이게 BCC 로 발송됨. (BCC 폴백 경로)
#   ※ 도메인 인증 전에는 'Resend 가입에 쓴 본인 이메일' 한 개만 발송 가능(서비스 제약).
EMAIL_RECIPIENTS=
# (선택, 권장) Resend 오디언스 ID — 설정하면 Broadcasts 경로로 발송 + 호스팅 1클릭 수신거부 자동.
#   설정 방법(1회): ① 발신 도메인(youngfoods.com.au) 인증 → EMAIL_FROM 을 회사 주소로 교체.
#     ② python bot/email_sender.py create-audience "GnC 시장리포트 구독자"  → 출력된 id 를 아래에 기입.
#     ③ python bot/email_sender.py import-recipients   (EMAIL_RECIPIENTS 를 오디언스로 이관)
#   비워두면 위 EMAIL_RECIPIENTS 를 BCC 로 발송(수신거부 자동화 없음).
RESEND_AUDIENCE_ID=
# (선택) 제목 앞 머리말. 예: "[GnC 시장리포트] "
EMAIL_SUBJECT_PREFIX=
